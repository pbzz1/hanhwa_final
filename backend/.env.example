# MySQL 연결 문자열 (mysql://user:password@host:port/database)
DATABASE_URL="mysql://user:password@localhost:3307/hanhwa_final"

# JWT 서명용 시크릿 (32자 이상 랜덤 문자열 권장)
JWT_SECRET="your_jwt_secret_key"

# 백엔드 서버 포트
PORT=3308

# AI 추론 서버 URL
AI_INFERENCE_URL=http://127.0.0.1:8001

# (선택) OSRM 라우팅 베이스 URL — 미설정 시 공개 데모 서버 사용
# OSRM_BASE_URL=https://router.project-osrm.org

# 프로덕션 배포 시에만: NODE_ENV=production 이면 CORS는 아래 출처만 허용 (쉼표 구분)
# FRONTEND_ORIGIN=https://your.domain,https://www.your.domain
