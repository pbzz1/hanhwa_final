# Kakao Map API 키 (https://developers.kakao.com 에서 발급)
VITE_KAKAO_MAP_APP_KEY=your_kakao_map_api_key

# Nest API (선택).
# 개발(vite): 비우면 같은 오리진(/auth,/map,/ai) + Vite 프록시 → localhost:3308 (ngrok HTTPS에도 안전).
# 배포: API가 다른 도메인이면 빌드 시 반드시 지정 — VITE_API_BASE_URL=https://api.example.com
# VITE_API_BASE_URL=
