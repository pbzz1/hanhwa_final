# Kakao Map API 키 (https://developers.kakao.com 에서 발급)
VITE_KAKAO_MAP_APP_KEY=your_kakao_map_api_key

# Nest API (선택). 비우거나 주석 처리하면 브라우저가 연 호스트와 동일 IP + 3308 을 씁니다.
# 예: http://192.168.0.10:5173 접속 → API는 http://192.168.0.10:3308
# 배포 빌드 시에만 절대 URL 권장: VITE_API_BASE_URL=https://api.example.com
# VITE_API_BASE_URL=
